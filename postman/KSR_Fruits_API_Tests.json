  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Customer - Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include(\"OTP sent\");",
                  "});",
                  "",
                  "pm.test(\"Phone number returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.phone).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{auth_base_url}}/api/auth/send-otp",
              "host": ["{{auth_base_url}}"],
              "path": ["api", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Customer - Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token received\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.collectionVariables.set(\"user_token\", jsonData.token);",
                  "    pm.collectionVariables.set(\"user_id\", jsonData.userId);",
                  "});",
                  "",
                  "pm.test(\"User role is USER\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql(\"USER\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\"\n}"
